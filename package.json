{
  "name": "alcohol-discovery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous agentic discovery of new alcohol products into Supabase Postgres. Web/API on Vercel; discovery on a separate worker.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "db:init": "set -a && . ./.env && psql \"$DATABASE_URL\" -f db/schema.sql",
    "discover": "tsx src/cli.ts discover",
    "test-run": "tsx src/cli.ts discover --test",
    "server": "tsx src/server/index.ts",
    "worker": "tsx src/worker.ts",
    "build": "tsc --outDir dist && cp -r src/server/public dist/server/public",
    "build:vercel": "npm run build && mkdir -p public && cp src/server/public/index.html public/index.html",
    "start": "node dist/server/index.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.100.1",
    "dotenv": "16.4.7",
    "express": "^4.22.2",
    "pg": "8.13.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "tsx": "^4.22.4",
    "typescript": "5.7.2"
  }
}
