# --- Database (Supabase Postgres) ---
# Use the CONNECTION POOLER URL from Supabase: click "Connect" in the dashboard
# top bar -> Connection string -> "Transaction pooler" (port 6543). The pooler is
# what you want for serverless (Vercel) so you don't exhaust direct connections.
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# TLS is auto-enabled for non-localhost hosts. Local Postgres also works:
#   postgres://postgres:postgres@localhost:5432/alcohol_discovery
DATABASE_URL=

# --- Anthropic (powers the agentic web-discovery source) ---
# Get a key at https://console.anthropic.com/. If unset, the agentic web
# source is skipped automatically; API connectors still run.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- COLA Cloud (primary new-product feed; enriched TTB COLA registry) ---
# Sign up at https://colacloud.us/. If unset, this source is skipped.
COLACLOUD_API_KEY=
COLACLOUD_BASE_URL=https://colacloud.us/api

# --- Open Brewery DB (free, no key required) ---
OPENBREWERYDB_BASE_URL=https://api.openbrewerydb.org/v1

# --- Server (local dev only; Vercel sets PORT itself) ---
PORT=4317

# --- Worker (optional tuning) ---
# How often the worker polls Supabase for queued runs, in ms.
WORKER_POLL_MS=3000
# Max DB pool connections per process (keep small for serverless).
PGPOOL_MAX=3
